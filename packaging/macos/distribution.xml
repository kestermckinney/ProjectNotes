<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">

    <title>Project Notes @VERSION@</title>
    <organization>com.projectnotespro</organization>

    <!-- Always install to /Applications on the system volume. -->
    <domains enable_localSystem="true" enable_userDomain="false"/>
    <options customize="allow" require-scripts="false" rootVolumeOnly="true"/>

    <!-- Minimum macOS version (must match CMAKE_OSX_DEPLOYMENT_TARGET) -->
    <volume-check>
        <allowed-os-versions>
            <os-version min="13.0"/>
        </allowed-os-versions>
    </volume-check>

    <!-- Installer UI resources (files placed in packaging/macos/resources/) -->
    <background file="background.png" alignment="bottomleft" scaling="proportional"/>
    <welcome file="welcome.html" mime-type="text/html"/>
    <license file="license.rtf" mime-type="text/rtf"/>

    <!-- ── Package declarations ── -->
    <pkg-ref id="com.projectnotespro.ProjectNotes"/>

    <!-- ── Install choices ── -->
    <choices-outline>
        <line choice="com.projectnotespro.ProjectNotes"/>
    </choices-outline>

    <!-- ProjectNotes is required (not optional) -->
    <choice id="com.projectnotespro.ProjectNotes"
            visible="false"
            enabled="false"
            selected="true"
            title="Project Notes"
            description="Project management application — tracks notes, meetings, issues, action items, contacts, and clients. Visit www.projectnotespro.com to download the companion mobile application and to manage your online data storage subscription.">
        <pkg-ref id="com.projectnotespro.ProjectNotes"/>
    </choice>

    <!-- ── pkg-ref payloads (resolved relative to the distribution file) ── -->
    <pkg-ref id="com.projectnotespro.ProjectNotes"
             version="@VERSION@"
             onConclusion="none">ProjectNotes.pkg</pkg-ref>

</installer-gui-script>
