<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">

    <title>Project Notes 5.0.0</title>
    <organization>com.kestermckinney</organization>

    <!-- Always install to /Applications on the system volume. -->
    <domains enable_localSystem="true" enable_userDomain="false"/>
    <options customize="allow" require-scripts="false" rootVolumeOnly="true"/>

    <!-- Minimum macOS version (must match CMAKE_OSX_DEPLOYMENT_TARGET) -->
    <volume-check>
        <allowed-os-versions>
            <os-version min="13.0"/>
        </allowed-os-versions>
    </volume-check>

    <!-- Installer UI resources (files placed in packaging/macos/resources/) -->
    <background file="background.png" alignment="bottomleft" scaling="proportional"/>
    <welcome file="welcome.html" mime-type="text/html"/>
    <license file="license.rtf" mime-type="text/rtf"/>

    <!-- ── Package declarations ── -->
    <pkg-ref id="com.kestermckinney.projectnotes"/>
    <pkg-ref id="com.sqlitesyncpro.sqladmin"/>
    <pkg-ref id="com.kestermckinney.projectnotes.ifsplugins"/>

    <!-- ── Install choices ── -->
    <choices-outline>
        <line choice="com.kestermckinney.projectnotes"/>
        <line choice="com.sqlitesyncpro.sqladmin"/>
        <line choice="com.kestermckinney.projectnotes.ifsplugins"/>
    </choices-outline>

    <!-- ProjectNotes is required (not optional) -->
    <choice id="com.kestermckinney.projectnotes"
            visible="false"
            enabled="false"
            selected="true"
            title="Project Notes"
            description="Project management application — tracks notes, meetings, issues, action items, contacts, and clients.">
        <pkg-ref id="com.kestermckinney.projectnotes"/>
    </choice>

    <!-- Project Notes Remote Host is optional but selected by default -->
    <choice id="com.sqlitesyncpro.sqladmin"
            visible="true"
            enabled="true"
            selected="true"
            title="Project Notes Remote Host"
            description="Configures and manages the remote host server for Project Notes cloud synchronization.">
        <pkg-ref id="com.sqlitesyncpro.sqladmin"/>
    </choice>

    <!-- IFS custom plugins are optional and unselected by default -->
    <choice id="com.kestermckinney.projectnotes.ifsplugins"
            visible="true"
            enabled="true"
            selected="false"
            title="IFS Custom Plugins"
            description="Custom plugins for IFS Cloud integration: SSRS report generation, IFS Cloud settings, and IFS synchronization support.">
        <pkg-ref id="com.kestermckinney.projectnotes.ifsplugins"/>
    </choice>

    <!-- ── pkg-ref payloads (resolved relative to the distribution file) ── -->
    <pkg-ref id="com.kestermckinney.projectnotes"
             version="5.0.0"
             onConclusion="none">ProjectNotes.pkg</pkg-ref>

    <pkg-ref id="com.sqlitesyncpro.sqladmin"
             version="0.1.0"
             onConclusion="none">ProjectNotesRemoteHost.pkg</pkg-ref>

    <pkg-ref id="com.kestermckinney.projectnotes.ifsplugins"
             version="5.0.0"
             onConclusion="none">IFSPlugins.pkg</pkg-ref>

</installer-gui-script>
