<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">

    <title>Project Notes Remote Host @VERSION@</title>
    <organization>com.sqlitesyncpro</organization>

    <!-- Always install to /Applications on the system volume. -->
    <domains enable_localSystem="true" enable_userDomain="false"/>
    <options customize="never" require-scripts="false" rootVolumeOnly="true"/>

    <!-- Minimum macOS version (must match CMAKE_OSX_DEPLOYMENT_TARGET) -->
    <volume-check>
        <allowed-os-versions>
            <os-version min="13.0"/>
        </allowed-os-versions>
    </volume-check>

    <!-- Installer UI resources (files placed in packaging/macos/resources/) -->
    <background file="background.png" alignment="bottomleft" scaling="proportional"/>
    <welcome file="welcome.html" mime-type="text/html"/>
    <license file="license.rtf" mime-type="text/rtf"/>

    <!-- ── Package declarations ── -->
    <pkg-ref id="com.sqlitesyncpro.sqladmin"/>

    <!-- ── Install choices ── -->
    <choices-outline>
        <line choice="com.sqlitesyncpro.sqladmin"/>
    </choices-outline>

    <!-- Remote Host is required (the only component in this installer) -->
    <choice id="com.sqlitesyncpro.sqladmin"
            visible="false"
            enabled="false"
            selected="true"
            title="Project Notes Remote Host"
            description="Configures and manages the remote host server for Project Notes cloud synchronization.">
        <pkg-ref id="com.sqlitesyncpro.sqladmin"/>
    </choice>

    <!-- ── pkg-ref payload (resolved relative to the distribution file) ── -->
    <pkg-ref id="com.sqlitesyncpro.sqladmin"
             version="@VERSION@"
             onConclusion="none">ProjectNotesRemoteHost.pkg</pkg-ref>

</installer-gui-script>
